  file_change {
    absolute_path_uri: "file:///src/components/PDFReader.tsx"
    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "    const handleMove = (e: MouseEvent | TouchEvent) => {\n      if (isSelectionActiveRef.current) {\n        const clientX = \'touches\' in e ? e.touches[0].clientX : e.clientX;\n        const clientY = \'touches\' in e ? e.touches[0].clientY : e.clientY;\n        const element = document.elementFromPoint(clientX, clientY);\n        if (element && !element.closest(\'.textLayer\')) {\n          console.warn(\"[SelectionGuard] Pointer left .textLayer! Current element:\", element.tagName, element.className, element.id);\n        }\n      }\n    };\n"
      replacement_content: "    const handleMove = (e: MouseEvent | TouchEvent) => {\n      if (isSelectionActiveRef.current) {\n        const clientX = \'touches\' in e ? e.touches[0].clientX : e.clientX;\n        const clientY = \'touches\' in e ? e.touches[0].clientY : e.clientY;\n        const element = document.elementFromPoint(clientX, clientY);\n        // On mobile, sometimes it hits the handle which is OS-level, or a span.\n        // If it hits something that isn\'t the textLayer but selection is active, we might have a problem.\n        if (element && !element.closest(\'.textLayer\')) {\n          const sel = window.getSelection();\n          if (sel && sel.type === \'Range\') {\n            console.warn(\"[SelectionGuard] Pointer at outside node during selection:\", element.tagName, element.className, element.id);\n          }\n        }\n      }\n    };\n"
    }
    replacement_chunks {
      target_content: "  const handlePanStart = (e: any, info: any) => {\n    try {\n      if (isSelectionActiveRef.current) return;\n      // If we are already in a specific mode, don\'t re-evaluate\n"
      replacement_content: "  const handlePanStart = (e: any, info: any) => {\n    try {\n      const selection = window.getSelection();\n      if (isSelectionActiveRef.current || (selection && selection.type === \'Range\')) return;\n      // If we are already in a specific mode, don\'t re-evaluate\n"
    }
    replacement_chunks {
      target_content: "  const handlePanMove = (_: any, info: any) => {\n    try {\n      // If in SelectingText, browsers handle everything\n      if (gestureMode.current === GestureMode.SelectingText || isAnimatingZoom.current) return;\n\n      // Movement threshold check to cancel long press\n"
      replacement_content: "  const handlePanMove = (_: any, info: any) => {\n    try {\n      const selection = window.getSelection();\n      const isSelectionRange = selection && selection.type === \'Range\' && !selection.isCollapsed;\n\n      // If in SelectingText or browser is selecting, browsers handle everything\n      if (gestureMode.current === GestureMode.SelectingText || isSelectionRange || isSelectionActiveRef.current || isAnimatingZoom.current) return;\n\n      // Movement threshold check to cancel long press\n"
    }
    diff {
