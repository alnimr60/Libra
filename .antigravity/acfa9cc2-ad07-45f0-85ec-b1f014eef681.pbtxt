    instruction: "Refine the selection loop to use range.getClientRects() exclusively and filter out rects that clearly fall outside the current page layer, preventing the \"select all\" jump."
    replacement_infos {
      original_chunk {
        target_content: "      const layerRect = layer.getBoundingClientRect();\n      const scaleX = layerRect.width / layer.offsetWidth || 1;\n      const scaleY = layerRect.height / layer.offsetHeight || 1;\n      const rawRects: { x: number, y: number, w: number, h: number }[] = [];\n\n      for (let i = 0; i < selection.rangeCount; i++) {\n        const range = selection.getRangeAt(i);\n        const rects = range.getClientRects();\n        for (let j = 0; j < rects.length; j++) {\n          const rect = rects[j];\n          if (\n            rect.right <= layerRect.left + 1 ||\n            rect.left >= layerRect.right - 1 ||\n            rect.bottom <= layerRect.top + 1 ||\n            rect.top >= layerRect.bottom - 1\n          ) continue;\n\n          const clampX = Math.max(rect.left, layerRect.left);\n          const clampY = Math.max(rect.top, layerRect.top);\n          const clampR = Math.min(rect.right, layerRect.right);\n          const clampB = Math.min(rect.bottom, layerRect.bottom);\n\n          if (clampR > clampX && clampB > clampY) {\n            rawRects.push({\n              x: (clampX - layerRect.left) / scaleX,\n              y: (clampY - layerRect.top) / scaleY,\n              w: (clampR - clampX) / scaleX,\n              h: (clampB - clampY) / scaleY\n            });\n          }\n        }\n      }\n"
        replacement_content: "      const layerRect = layer.getBoundingClientRect();\n      const rawRects: { x: number, y: number, w: number, h: number }[] = [];\n\n      for (let i = 0; i < selection.rangeCount; i++) {\n        const range = selection.getRangeAt(i);\n        \n        // Safety check: if selection is not contained within our layer, it might have jumped outside\n        if (!layer.contains(range.commonAncestorContainer) && range.commonAncestorContainer !== layer) {\n          // If range starts or ends outside, browser might have jumped to a distant node\n          const isStartIn = layer.contains(range.startContainer);\n          const isEndIn = layer.contains(range.endContainer);\n          if (!isStartIn && !isEndIn) {\n            setSelectionRects([]);\n            return;\n          }\n        }\n\n        const rects = range.getClientRects();\n        for (let j = 0; j < rects.length; j++) {\n          const rect = rects[j];\n          \n          // Use a tighter intersection check\n          const intersectionX = Math.max(rect.left, layerRect.left);\n          const intersectionY = Math.max(rect.top, layerRect.top);\n          const intersectionR = Math.min(rect.right, layerRect.right);\n          const intersectionB = Math.min(rect.bottom, layerRect.bottom);\n\n          if (intersectionR > intersectionX + 0.5 && intersectionB > intersectionY + 0.5) {\n            // Also ensure the rect center is inside the layer to avoid edge cases\n            const centerX = rect.left + rect.width / 2;\n            const centerY = rect.top + rect.height / 2;\n            \n            if (centerX >= layerRect.left && centerX <= layerRect.right && \n                centerY >= layerRect.top && centerY <= layerRect.bottom) {\n              rawRects.push({\n                x: (intersectionX - layerRect.left) / (layerRect.width / layer.offsetWidth),\n                y: (intersectionY - layerRect.top) / (layerRect.height / layer.offsetHeight),\n                w: (intersectionR - intersectionX) / (layerRect.width / layer.offsetWidth),\n                h: (intersectionB - intersectionY) / (layerRect.height / layer.offsetHeight)\n              });\n            }\n          }\n        }\n      }\n"
