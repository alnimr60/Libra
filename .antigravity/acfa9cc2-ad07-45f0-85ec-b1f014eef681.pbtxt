        }
        lines {
          text: "      const t1 = e.touches[0];"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      const t2 = e.touches[1];"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      const dist = Math.hypot(t1.pageX - t2.pageX, t1.pageY - t2.pageY);"
